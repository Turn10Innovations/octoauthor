# OctoAuthor Environment Configuration
# Copy this to .env and fill in your values. NEVER commit .env.

# =============================================================================
# API Authentication
# =============================================================================
# Key for orchestrators (OpenClaw) to connect to OctoAuthor
OCTOAUTHOR_API_KEY=change-me-to-a-real-secret

# Separate key for the auditor agent (different trust level)
OCTOAUTHOR_AUDITOR_API_KEY=change-me-different-from-above

# =============================================================================
# LLM Providers
# =============================================================================
# Text generation (for writing docs) — default: local Ollama
OCTOAUTHOR_TEXT_PROVIDER=ollama
OCTOAUTHOR_TEXT_MODEL=qwen3:32b
OCTOAUTHOR_TEXT_BASE_URL=http://host.docker.internal:11434

# Vision (for screenshot analysis) — optional
# OCTOAUTHOR_VISION_PROVIDER=anthropic
# OCTOAUTHOR_VISION_MODEL=claude-sonnet-4-6

# QA review — optional (uses text provider if not set)
# OCTOAUTHOR_QA_PROVIDER=anthropic
# OCTOAUTHOR_QA_MODEL=claude-sonnet-4-6

# Audit (security review) — should be a strong model
OCTOAUTHOR_AUDIT_PROVIDER=anthropic
OCTOAUTHOR_AUDIT_MODEL=claude-sonnet-4-6

# Provider API keys (only needed for cloud providers)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# =============================================================================
# Ports
# =============================================================================
OCTOAUTHOR_API_PORT=8000
OCTOAUTHOR_MCP_SCREENSHOT=8100
OCTOAUTHOR_MCP_WRITER=8101
OCTOAUTHOR_MCP_STORE=8102
OCTOAUTHOR_MCP_VISUAL=8103
OCTOAUTHOR_MCP_INSPECTOR=8104

# =============================================================================
# Logging
# =============================================================================
OCTOAUTHOR_LOG_LEVEL=INFO

# =============================================================================
# GitHub (for auditor PR reviews)
# =============================================================================
# OCTOAUTHOR_AUDITOR_GITHUB_TOKEN=ghp_...
