# OctoAuthor Configuration
# Copy this file to .env and adjust values as needed.
# All settings use the OCTOAUTHOR_ prefix and are loaded by pydantic-settings.

# ── Ports ─────────────────────────────────────────────────────────────────────
# Change these if the defaults conflict with other services on your machine.
OCTOAUTHOR_API_PORT=9210
OCTOAUTHOR_MCP_PORT_SCREENSHOT=9211
OCTOAUTHOR_MCP_PORT_DOC_WRITER=9212
OCTOAUTHOR_MCP_PORT_DOC_STORE=9213
OCTOAUTHOR_MCP_PORT_VISUAL_QA=9214
OCTOAUTHOR_MCP_PORT_APP_INSPECTOR=9215

# ── Logging ───────────────────────────────────────────────────────────────────
OCTOAUTHOR_LOG_LEVEL=INFO

# ── LLM Providers ────────────────────────────────────────────────────────────
# Text generation (used for doc writing)
OCTOAUTHOR_TEXT_PROVIDER=ollama
OCTOAUTHOR_TEXT_MODEL=qwen3:32b
OCTOAUTHOR_TEXT_BASE_URL=http://host.docker.internal:11434

# Audit provider (used for PR review — should be a strong model)
# OCTOAUTHOR_AUDIT_PROVIDER=anthropic
# OCTOAUTHOR_AUDIT_MODEL=claude-sonnet-4-6

# ── API Keys ──────────────────────────────────────────────────────────────────
# API key for orchestrator authentication to the discovery API
# OCTOAUTHOR_API_KEY=your-api-key-here

# Separate API key for the auditor agent
# OCTOAUTHOR_AUDITOR_API_KEY=your-auditor-key-here

# GitHub PAT for PR operations (auditor + integrations)
# GITHUB_TOKEN=ghp_your_token_here

# ── Output Paths ──────────────────────────────────────────────────────────────
# These default to docs/user-guide and docs/user-guide/assets respectively.
# Override for Docker or custom setups.
# OCTOAUTHOR_DOC_OUTPUT_DIR=docs/user-guide
# OCTOAUTHOR_SCREENSHOT_OUTPUT_DIR=docs/user-guide/assets
